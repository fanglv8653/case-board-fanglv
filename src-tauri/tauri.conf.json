{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "方律案件看板",
  "version": "0.6.1",
  "identifier": "com.fanglv.caseboard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "方律案件看板",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "resources": {
      "../standalone/court_filing_cli": "standalone/court_filing_cli"
    },
    "shortDescription": "方律个人案件看板",
    "longDescription": "方律案件看板 — 基于 CaseBoard 二创的个人 Windows 办案工作台,本地优先、不改动源文件。保留诉讼、执行、非诉、工具、团队、AI 和收入台账等模块,高级能力按配置逐步启用。",
    "copyright": "Copyright © 2026 CaseBoard Contributors",
    "publisher": "Fanglv",
    "homepage": "https://github.com/fanglv8653/case-board-fanglv",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1MkRGODBFOTM2RTA0MjIKUldRaUJHNlREdmd0UmVEWm1tU1NkTUY2R3JHQ0lmc2xEK09oN1JiTWdzMmdpRkJiaVk3L0JXRHYK",
      "endpoints": [
        "https://raw.githubusercontent.com/fanglv8653/case-board-fanglv/main/release/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
